# Configurações do Servidor
PORT=3000
NODE_ENV=development

# ========================================
# Configurações do Banco de Dados PostgreSQL (Neon)
# ========================================

# OPÇÃO 1: Usar a URL de conexão do Neon (RECOMENDADO)
# Copie a URL de conexão fornecida pelo Neon no dashboard
# Exemplo: postgresql://seu_usuario:sua_senha@ep-seu-projeto.neon.tech/seu_banco?sslmode=require
# DATABASE_URL=postgresql://seu_usuario:sua_senha@ep-seu-projeto.neon.tech/seu_banco?sslmode=require

# OPÇÃO 2: Ou configure as variáveis individuais abaixo
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=igreja_alunos
